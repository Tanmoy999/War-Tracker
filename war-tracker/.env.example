# Real-time Data API Configuration
# Copy this to .env and fill in your actual API keys

# NewsAPI.org - Free tier available at https://newsapi.org
# Used to fetch news articles about Iran-Israel-USA conflict
NEWS_API_KEY=your_newsapi_key_here

# The Guardian API - Free tier available at https://open-platform.theguardian.com
# Used to fetch articles from The Guardian
GUARDIAN_API_KEY=your_guardian_api_key_here

# Optional: Add more API keys here as you integrate more data sources
# WORLD_BANK_API_KEY=your_worldbank_key
# US_MILITARY_API_KEY=your_military_api_key
